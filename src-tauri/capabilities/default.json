{
  "identifier": "default",
  "description": "Default capabilities for Show Timer",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:allow-load",
    "store:allow-save",
    "store:allow-set",
    "store:allow-get",
    "store:allow-delete",
    "store:allow-clear",
    "store:allow-keys",
    "store:allow-entries",
    "store:allow-has",
    "store:allow-length",
    "store:allow-values",
    "store:allow-reset",
    "notification:allow-request-permission",
